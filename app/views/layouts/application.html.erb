<!DOCTYPE html>
<html lang="<%=I18n.locale %>">
<head>
  <meta charset="utf-8">
  <%=display_meta_tags  %>
  <meta name="author" content="Sleeping-Lion">
  <link rel="alternate" type="application/rss+xml" title="Anti-KB RSS Feed" href="<%= t(:site_full_url) %>/feed?format=rss">
  <%= stylesheet_link_tag "front", :media => "all", "data-turbolinks-track" => true %>
  <%= stylesheet_link_tag "actiontext", :media => "all", "data-turbolinks-track" => true %>
  <%= favicon_link_tag '/favicon.ico' %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag -%>
  <%= yield :json_ld %>
</head>
<body>
  <%= render :partial => 'layouts/header' %>
      <div id="mom">
        <div id="main" class="container">
          <div class="sub-main">
            <div class="row">
              <%= render :partial => 'layouts/ad' %>
              <%= render :partial => 'layouts/aside' %>
            </div>
            <%= render :partial => 'layouts/notice', :locals=>{ :notice=>notice,:alert=>alert} %>
            <div class="row">
              <%= yield %>
            </div>
          </div>
        </div>
      </div>
      <%= render :partial => 'layouts/footer' %>
  <div class="modal fade" id="myModal" tabindex="-1" role="dialog"></div>
  <%= javascript_importmap_tags %>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-T2S7K0KYVH"></script>
  <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-T2S7K0KYVH');
  </script>
</body>
</html>
